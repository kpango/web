{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "react-jsx",
    "jsxImportSource": "hono/jsx",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@kpango/ui/*": ["../../packages/ui/src/*"],
      "@kpango/ui": ["../../packages/ui/src/index.ts"],
      "@kpango/content/*": ["../../packages/content/*"],
      "@kpango/content": ["../../packages/content/src/index.ts"],
      "@kpango/search/*": ["../../packages/search/src/*"],
      "@kpango/search": ["../../packages/search/src/index.ts"]
    }
  },
  "include": [
    "src",
    "api",
    "index.tsx",
    "../../packages/ui/src",
    "../../packages/content/src",
    "../../packages/search/src"
  ],
  "exclude": ["node_modules", "dist"]
}
